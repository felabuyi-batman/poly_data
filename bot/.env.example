# Bot config — copy to .env and edit.

# OpenAI (drives the news + disposition + estimate checks)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
LLM_CACHE_TTL_SEC=1800

# Stay in paper trading until you've reviewed everything.
DRY_RUN=true
BANKROLL_USD=200

# Required only when DRY_RUN=false (or use `polymarket setup`).
POLY_PRIVATE_KEY=
POLY_FUNDER_ADDRESS=
CLOB_HOST=https://clob.polymarket.com
CLOB_CHAIN_ID=137

# Filters (defaults match the article).
TARGETS_MIN_TRADES=100
TARGETS_MIN_WIN_RATE=0.70
TARGETS_TOP_N=50

SCAN_MIN_GAP=0.07
SCAN_MIN_DEPTH_USD=500
SCAN_MIN_HOURS=4
SCAN_MAX_HOURS=168
MIN_MARKET_VOLUME_USD=50000

BRAIN_MIN_CONFIDENCE=0.75
BRAIN_MIN_CHECKS_AGREEING=3
KELLY_MAX_FRACTION=0.25

WHALE_COPY_CATEGORIES=crypto

EXIT_TARGET_PCT=0.85
EXIT_VOLUME_SPIKE_MULT=3.0
EXIT_STALE_HOURS=24
EXIT_STALE_MAX_MOVE=0.02

# Force CLI usage (error instead of HTTP fallback)
POLYMARKET_REQUIRE_CLI=0
